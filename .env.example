# Google Cloud Vision API key
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# Anthropic API key for Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Vercel KV for rate limiting (if using Vercel KV)
# KV_REST_API_URL=your_vercel_kv_url
# KV_REST_API_TOKEN=your_vercel_kv_token

# Optional: PostHog scan-event analytics (api/_analytics.js).
# When unset, trackScan() is a no-op — analytics is off in dev/test by default.
# POSTHOG_API_KEY=phc_your_project_api_key_here
# POSTHOG_HOST=https://us.i.posthog.com  # use the EU host if your project is EU-cloud
